# FranchiseConnect Backend - Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Connection
# For local development: mongodb://localhost:27017/franchiseconnect
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/franchiseconnect
MONGO_URI=mongodb://localhost:27017/franchiseconnect

# JWT Configuration
# Use a strong random string (at least 32 characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email Configuration (for interest request notifications)
# Gmail SMTP settings
# You need to enable 2FA and create an app password
# See: https://support.google.com/accounts/answer/185833
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_16_characters

# Server Configuration
PORT=5000
NODE_ENV=development

# Optional: Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:5173

# Optional: Logging
LOG_LEVEL=debug
